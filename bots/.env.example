# ─────────────────────────────────────────────────────────────────────────────
# Bot Vault Pro — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── SUBSCRIPTION TIER ────────────────────────────────────────────────────────
# Options: starter | growth | enterprise
# starter    ($49/mo):   25 leads/run, blog only, 50 tickets/mo, manual reply
# growth     ($149/mo):  250 leads/run, all platforms, 500 tickets/mo, IMAP polling
# enterprise (custom):   Unlimited everything, all features
SUBSCRIPTION_TIER=starter

# ── REQUIRED (all bots) ──────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── LEADGEN PRO BOT ──────────────────────────────────────────────────────────
# Describe your ideal customer. Be specific — AI uses this to score leads.
ICP_DESCRIPTION=SaaS companies with 10-200 employees in the US looking to automate sales or support workflows

# Path to the file with target domains (one domain per line)
TARGET_DOMAINS_FILE=leadgen/knowledge/sample-targets.txt

# ── CONTENTBLAST BOT ─────────────────────────────────────────────────────────
# Describe your brand's writing style. Used in all content generation.
BRAND_VOICE=Professional but approachable. Data-driven insights, no corporate jargon. Conversational tone with a slight sense of humor.

# Twitter/X API credentials (get from https://developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn API credentials (get from https://developer.linkedin.com)
# LINKEDIN_PERSON_URN format: urn:li:person:XXXXXXXXX
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# ── SUPPORTDESK BOT ──────────────────────────────────────────────────────────
# Your company name (used in AI reply signature and tone)
COMPANY_NAME=Bot Vault Pro

# Minimum AI confidence (0.0–1.0) to auto-reply. Below this → escalate to human.
AUTO_REPLY_MIN_CONFIDENCE=0.7

# Email address to notify when a ticket needs human review
ESCALATION_EMAIL=support@yourdomain.com

# ── EMAIL / SMTP (LeadGen + SupportDesk) ─────────────────────────────────────
# Works with Gmail, SendGrid, Mailgun, etc.
# For Gmail: use App Password (not your main password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Display name and email shown in From: field
FROM_NAME=Your Name
FROM_EMAIL=your@gmail.com
FROM_COMPANY=Your Company Name

# ── IMAP (SupportDesk — incoming email) ──────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=support@yourdomain.com
IMAP_PASS=your-app-password
